# Required public origin of the NestJS API, with no path/query/fragment.
# The browser and the Next.js server use this same directly reachable origin.
# Vercel must receive this value during the production build.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google OAuth web client ID. Must match the API's GOOGLE_CLIENT_ID_WEB
# (the API verifies the ID-token audience against that value). Leave
# empty to hide the Google sign-in button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
