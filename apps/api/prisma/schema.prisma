// Auth subsystem schema. Business models land in later PRs.
//
// Design references:
// - docs/adr/0002-cookie-based-sessions.md         (cookies, no authjs)
// - docs/adr/0003-multi-instance-refresh-rotation.md (previous_jti + pendingTokenHash)
// - docs/auth/sessions-and-audit.md                 (this PR — what each table is for)
//
// Every model that ties to a user uses `onDelete: Cascade` so DELETE /v1/auth/me
// in PR 5 wipes the user's full footprint atomically. The single exception is
// AuditEvent which uses `SetNull` — we keep audit history after account deletion
// for compliance / forensics; rows are simply detached from the gone user.

// Canonical Prisma 7 generator block. See AGENTS.md → prisma-verify-rule.
// - `prisma-client` (not the deprecated `prisma-client-js`)
// - `engineType = "client"` (WASM compiler, no Rust binary)
// - `output` is required in v7 and lives outside node_modules; consumers
//   import from `../src/generated/prisma/client` rather than `@prisma/client`.
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  engineType   = "client"
  moduleFormat = "cjs"
}

// The `url` lives in `prisma.config.ts` from Prisma 7 onward. Migrate +
// generate commands read it from there; the runtime PrismaClient (later
// PR) gets it via the PrismaPg driver adapter.
datasource db {
  provider = "postgresql"
}

/// A human. `emailVerified` / `phoneVerified` are timestamps (not
/// booleans) — when verified is the audit trail.
///
/// Email-and-password login isn't part of the v1 template — every auth
/// method here proves identity via a channel (OTP) or an OAuth provider.
/// If a future variant needs password login, add `passwordHash` back via
/// migration; nothing else has to move.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  phoneVerified DateTime?
  firstName     String?
  lastName      String?
  /// Authorization roles. Snapshotted into access-JWT claims at issue
  /// time; downstream services read `request.user.roles`. Re-read the
  /// DB for fresh values; the JWT can lag by up to JWT_ACCESS_TTL.
  roles         String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  /// Soft-delete marker. Hard cascade still runs via DELETE /v1/auth/me; this
  /// column is reserved for "deactivate" flows that may land later.
  deletedAt     DateTime?

  sessions      Session[]
  refreshTokens RefreshToken[]
  otpChallenges OtpChallenge[]
  authAccounts  AuthAccount[]
  auditEvents   AuditEvent[]

  @@index([email])
  @@index([phone])
}

/// First-class session record. One row per "logged-in device". Refresh-token
/// rotations within the same session reuse this row (only `lastUsedAt`
/// moves). Powers the user-visible "active devices" list and "log out other
/// devices" UI.
model Session {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent     String?
  ip            String?
  createdAt     DateTime       @default(now())
  lastUsedAt    DateTime       @default(now())
  revokedAt     DateTime?
  refreshTokens RefreshToken[]

  @@index([userId, revokedAt])
}

/// One row per refresh-token *value* ever minted. Multiple rows per session
/// (one per rotation). The cleanup cron deletes rows older than `expiresAt`.
///
/// - `tokenHash` is the SHA-256 HMAC of the plaintext token (peppered by
///   REFRESH_TOKEN_HMAC_SECRET). Stored, not the plaintext.
/// - `previousJti` chains a row to the row it replaced. Lets concurrent
///   refreshes within the grace window detect they're racing against an
///   already-rotated token without rejecting either caller.
/// - `pendingTokenHash` is reserved for a possible future literal
///   idempotency design. The current chain algorithm does not use it.
/// - `revokedAt` is set on rotation, on logout, and on full-session burn
///   (reuse detection).
model RefreshToken {
  id               String    @id @default(cuid())
  jti              String    @unique
  previousJti      String?   @unique
  pendingTokenHash String?
  sessionId        String
  session          Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash        String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([sessionId, revokedAt])
  @@index([userId, expiresAt])
  @@index([expiresAt])
}

/// One active proof per logical target. `activeKey` is cleared when the
/// challenge is consumed or superseded, allowing historical rows to remain
/// without blocking a new issuance.
///
/// The plaintext code is derived from this UUID and OTP_HMAC_SECRET, then only
/// its HMAC is persisted. Resends therefore deliver the same code without
/// storing recoverable plaintext.
model OtpChallenge {
  id            String    @id @default(uuid()) @db.Uuid
  activeKey     String?   @unique
  /// Currently "EMAIL"; reserved for future channel verification.
  channel       String
  /// "AUTH" | "OAUTH_EMAIL_VERIFY"
  purpose       String
  /// Normalized email or phone target.
  target        String
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// OAuth context is populated only for OAUTH_EMAIL_VERIFY.
  provider      String?
  providerId    String?
  firstName     String?
  lastName      String?
  codeHash      String
  expiresAt     DateTime
  usedAt        DateTime?
  attemptsCount Int       @default(0)
  sentCount     Int       @default(1)
  lastSentAt    DateTime  @default(now())
  nextSendAt    DateTime
  createdAt     DateTime  @default(now())

  @@index([channel, purpose, target, usedAt, expiresAt])
  @@index([provider, providerId, purpose, usedAt, expiresAt])
  @@index([userId])
  @@index([expiresAt])
}

/// Fixed-window counters for successful OTP delivery attempts.
///
/// `subjectHash` is an HMAC-derived target or IP identifier. No additional
/// plaintext email or IP data is stored here. Rows are independent of
/// challenges so limits survive challenge expiry, API restarts, and
/// multi-instance deployments.
model OtpDeliveryQuota {
  /// "TARGET_HOUR" | "TARGET_DAY" | "IP_HOUR"
  bucket      String
  subjectHash String
  windowStart DateTime
  windowEnd   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([bucket, subjectHash, windowStart])
  @@index([windowEnd])
}

/// One row per OAuth identity linked to a user. The `provider + providerId`
/// uniqueness prevents the same provider account from binding to two users.
///
/// `email` is captured opportunistically at link time for support and audit
/// context. Repeat logins resolve through the stable provider subject, so
/// providers may omit the email claim after the initial link.
model AuthAccount {
  id         String   @id @default(cuid())
  /// "google" | "apple"
  provider   String
  providerId String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String?
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

/// Append-only audit log. Survives user deletion (userId becomes null) so
/// forensics + compliance reports can reconstruct activity after the fact.
///
/// `type` values are defined in TS by `AuditEventType` and include:
/// SIGNUP, LOGIN_SUCCESS, LOGIN_FAIL, EMAIL_VERIFIED, OAUTH_LINKED,
/// OAUTH_UNLINKED, SESSION_REVOKED, SESSION_BURNED, LOGOUT_ALL,
/// ACCOUNT_DELETED, NEW_DEVICE_NOTIFIED.
model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
  @@index([type, createdAt])
}
