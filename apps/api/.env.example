# ==========================================================================
# Auto-generated by `pnpm gen:env`. DO NOT EDIT BY HAND.
# Source of truth: apps/api/src/config/env.ts
# ==========================================================================

# Runtime mode. Controls dev-only conveniences (e.g. OTP=000000).
# Required: no
# Default: development
NODE_ENV=development

# Port the API listens on.
# Required: no
# Default: 3000
PORT=3000

# Public base URL of the web app (used in emails, redirects).
# Required: no
# Default: http://localhost:3001
APP_BASE_URL=http://localhost:3001

# Public base URL of this API (used in OpenAPI servers list).
# Required: no
# Default: http://localhost:3000
API_BASE_URL=http://localhost:3000

# Cookie domain in production (e.g. ".example.com"). Leave empty in dev — Lax cookies on localhost work without it.
# Required: no
COOKIE_DOMAIN=

# Comma-separated list of allowed CORS origins. MUST be explicit when credentials are enabled (no "*").
# Required: no
# Default: http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# Postgres connection string. See docker-compose.yml for local defaults.
# Required: no
# Default: postgresql://app:app@localhost:5434/app
DATABASE_URL=postgresql://app:app@localhost:5434/app

# HMAC secret for access tokens. Min 32 chars. ROTATE per environment.
# Required: yes
JWT_ACCESS_SECRET=

# HMAC secret for refresh tokens. Min 32 chars. Distinct from JWT_ACCESS_SECRET.
# Required: yes
JWT_REFRESH_SECRET=

# Access-token lifetime (ms-format, e.g. "15m", "1h").
# Required: no
# Default: 15m
JWT_ACCESS_TTL=15m

# Refresh-token lifetime (ms-format, e.g. "90d").
# Required: no
# Default: 90d
JWT_REFRESH_TTL=90d

# SHA-256 HMAC pepper for refresh-token DB hashing. Distinct from JWT_REFRESH_SECRET. Min 32 chars.
# Required: yes
REFRESH_TOKEN_HMAC_SECRET=

# Window during which a concurrent refresh of the same token returns the literal same just-issued pair (option-B idempotency).
# Required: no
# Default: 10
ROTATION_GRACE_SECONDS=10

# Enable email-OTP login (request/verify endpoints).
# Required: no
# Default: true
AUTH_EMAIL_OTP_ENABLED=true

# Enable SMS-OTP login. Requires SMS_PROVIDER credentials.
# Required: no
# Default: false
AUTH_SMS_OTP_ENABLED=false

# Enable Google Sign-in (ID-token verification). Requires GOOGLE_CLIENT_ID_*.
# Required: no
# Default: false
AUTH_GOOGLE_ENABLED=false

# Enable Sign in with Apple. Requires APPLE_SERVICE_ID and/or APPLE_BUNDLE_ID as the audience.
# Required: no
# Default: false
AUTH_APPLE_ENABLED=false

# Google OAuth web client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_WEB=

# Google OAuth iOS client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_IOS=

# Google OAuth Android client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_ANDROID=

# Apple Service ID (web audience).
# Required: no
APPLE_SERVICE_ID=

# Apple iOS bundle ID (native audience).
# Required: no
APPLE_BUNDLE_ID=

# Apple Developer Team ID (reserved for future server-to-server token revocation).
# Required: no
APPLE_TEAM_ID=

# Apple Sign-in key ID (reserved for future server-to-server flows).
# Required: no
APPLE_KEY_ID=

# SHA-256 HMAC pepper for OTP-code DB hashing. Min 32 chars.
# Required: yes
OTP_HMAC_SECRET=

# OTP lifetime (ms-format, e.g. "10m").
# Required: no
# Default: 10m
OTP_TTL=10m

# Max wrong attempts before an OTP is locked.
# Required: no
# Default: 5
OTP_MAX_ATTEMPTS=5

# OTP digit length in production. In non-production NODE_ENV, OTPs are always "000000" regardless of this value.
# Required: no
# Default: 6
OTP_LENGTH=6

# Email provider. "log" prints to stdout (dev/test). "resend" uses Resend API. "smtp" uses nodemailer.
# Required: no
# Default: log
MAILER_PROVIDER=log

# From address used for outgoing mail.
# Required: no
# Default: no-reply@example.com
MAILER_FROM=no-reply@example.com

# Resend API key. Required when MAILER_PROVIDER=resend.
# Required: no
RESEND_API_KEY=

# SMTP host. Required when MAILER_PROVIDER=smtp.
# Required: no
SMTP_HOST=

# SMTP port. Required when MAILER_PROVIDER=smtp.
# Required: no
SMTP_PORT=

# SMTP username. Required when MAILER_PROVIDER=smtp.
# Required: no
SMTP_USER=

# SMTP password. Required when MAILER_PROVIDER=smtp.
# Required: no
SMTP_PASSWORD=

# SMS provider. "log" prints to stdout. "smso" uses SMSO.ro.
# Required: no
# Default: log
SMS_PROVIDER=log

# SMSO.ro API key. Required when SMS_PROVIDER=smso.
# Required: no
SMSO_API_KEY=

# SMSO.ro sender ID. Required when SMS_PROVIDER=smso.
# Required: no
SMSO_SENDER=

# Max OTP requests per IP per hour.
# Required: no
# Default: 20
THROTTLE_OTP_PER_IP_PER_HOUR=20

# Max OTP requests per email/phone per hour.
# Required: no
# Default: 5
THROTTLE_OTP_PER_TARGET_PER_HOUR=5

# Max OTP requests per email/phone per 24h.
# Required: no
# Default: 20
THROTTLE_OTP_PER_TARGET_PER_DAY=20

# Max login attempts per IP per minute.
# Required: no
# Default: 10
THROTTLE_LOGIN_PER_IP_PER_MIN=10

# Run daily 03:00 cleanup of expired refresh tokens and stale OTP rows.
# Required: no
# Default: true
AUTH_CLEANUP_ENABLED=true
