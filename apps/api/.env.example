# ==========================================================================
# Auto-generated by `pnpm gen:env`. DO NOT EDIT BY HAND.
# Source of truth: apps/api/src/config/env.ts
# ==========================================================================

# Runtime mode. Controls dev-only conveniences (e.g. OTP=000000).
# Required: no
# Default: development
NODE_ENV=development

# Port the API listens on.
# Required: no
# Default: 3000
PORT=3000

# Public base URL of the web app (used in emails, redirects).
# Required: no
# Default: http://localhost:3001
APP_BASE_URL=http://localhost:3001

# Public base URL of this API (used in OpenAPI servers list).
# Required: no
# Default: http://localhost:3000
API_BASE_URL=http://localhost:3000

# Maximum V8 heap usage in MiB before /healthz reports unhealthy.
# Required: no
# Default: 300
HEALTH_MAX_HEAP_MB=300

# Cookie domain in production (e.g. ".example.com"). Leave empty in dev — Lax cookies on localhost work without it.
# Required: no
COOKIE_DOMAIN=

# Comma-separated list of allowed CORS origins. MUST be explicit when credentials are enabled (no "*").
# Required: no
# Default: http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# Postgres connection string. See docker-compose.yml for local defaults.
# Required: no
# Default: postgresql://app:app@localhost:5434/app
DATABASE_URL=postgresql://app:app@localhost:5434/app

# Image storage backend. S3 is used for private media assets.
# Required: no
# Default: s3
IMAGE_STORAGE_DRIVER=s3

# Maximum accepted image upload size in bytes.
# Required: no
# Default: 10485760
IMAGE_STORAGE_MAX_BYTES=10485760

# Private S3 bucket name used for image storage. Required when IMAGE_STORAGE_DRIVER=s3.
# Required: no
IMAGE_STORAGE_S3_BUCKET=

# AWS region of IMAGE_STORAGE_S3_BUCKET. Required when IMAGE_STORAGE_DRIVER=s3.
# Required: no
IMAGE_STORAGE_S3_REGION=

# Object key prefix for private document-photo images.
# Required: no
# Default: document-photos
IMAGE_STORAGE_S3_PREFIX=document-photos

# Optional AWS KMS key ID/ARN for S3 SSE-KMS image uploads. Leave empty to use the bucket default encryption.
# Required: no
IMAGE_STORAGE_S3_KMS_KEY_ID=

# Lifetime in seconds for S3 signed image GET/PUT URLs.
# Required: no
# Default: 300
IMAGE_STORAGE_SIGNED_URL_TTL_SECONDS=300

# HMAC secret used to sign direct-upload completion tokens. Required when IMAGE_STORAGE_DRIVER=s3. Min 32 chars.
# Required: no
IMAGE_STORAGE_UPLOAD_TOKEN_SECRET=

# RSA private key (PEM, base64-encoded) used to sign access + refresh JWTs (RS256). In dev/test, auto-generated to .dev-keys/ on first start when unset. MUST be set explicitly in production.
# Required: yes
JWT_PRIVATE_KEY=

# RSA public key (PEM, base64-encoded) used to verify access + refresh JWTs (RS256). Exposed verbatim via /.well-known/jwks.json so first-party clients (Next.js RSC, microservices) can verify locally.
# Required: yes
JWT_PUBLIC_KEY=

# Previous RSA public key (PEM, base64-encoded), kept active during a key-rotation window. Published in /.well-known/jwks.json alongside the current key, and accepted by this API's verifier for any token whose `kid` header matches it. Unset means no rotation is in progress.
# Required: no
JWT_PUBLIC_KEY_PREVIOUS=

# Access-token lifetime (ms-format, e.g. "15m", "1h").
# Required: no
# Default: 15m
JWT_ACCESS_TTL=15m

# Refresh-token lifetime (ms-format, e.g. "90d").
# Required: no
# Default: 90d
JWT_REFRESH_TTL=90d

# SHA-256 HMAC pepper for refresh-token DB hashing. Independent of the JWT signing keypair (which protects the token wire-format); this one protects DB rows. Min 32 chars.
# Required: yes
REFRESH_TOKEN_HMAC_SECRET=

# Window during which concurrent refreshes can advance the same persisted token chain without triggering reuse detection.
# Required: no
# Default: 10
ROTATION_GRACE_SECONDS=10

# Enable email-OTP login (request/verify endpoints).
# Required: no
# Default: true
AUTH_EMAIL_OTP_ENABLED=true

# Enable Google Sign-in (ID-token verification). Requires GOOGLE_CLIENT_ID_*.
# Required: no
# Default: false
AUTH_GOOGLE_ENABLED=false

# Enable Sign in with Apple. Requires APPLE_SERVICE_ID and/or APPLE_BUNDLE_ID as the audience.
# Required: no
# Default: false
AUTH_APPLE_ENABLED=false

# Google OAuth web client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_WEB=

# Google OAuth iOS client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_IOS=

# Google OAuth Android client ID (audience for verification).
# Required: no
GOOGLE_CLIENT_ID_ANDROID=

# Apple Service ID (web audience).
# Required: no
APPLE_SERVICE_ID=

# Apple iOS bundle ID (native audience).
# Required: no
APPLE_BUNDLE_ID=

# Apple Developer Team ID (reserved for future server-to-server token revocation).
# Required: no
APPLE_TEAM_ID=

# Apple Sign-in key ID (reserved for future server-to-server flows).
# Required: no
APPLE_KEY_ID=

# SHA-256 HMAC pepper for OTP-code DB hashing. Min 32 chars.
# Required: yes
OTP_HMAC_SECRET=

# OTP lifetime (ms-format, e.g. "10m").
# Required: no
# Default: 10m
OTP_TTL=10m

# Max wrong attempts before an OTP is locked.
# Required: no
# Default: 5
OTP_MAX_ATTEMPTS=5

# OTP digit length in production. In non-production NODE_ENV, OTPs are always "000000" regardless of this value.
# Required: no
# Default: 6
OTP_LENGTH=6

# Max delivered OTP emails per normalized target per UTC hour.
# Required: no
# Default: 5
OTP_DELIVERY_QUOTA_PER_TARGET_PER_HOUR=5

# Max delivered OTP emails per normalized target per UTC day.
# Required: no
# Default: 20
OTP_DELIVERY_QUOTA_PER_TARGET_PER_DAY=20

# Max delivered OTP emails per direct client IP per UTC hour.
# Required: no
# Default: 20
OTP_DELIVERY_QUOTA_PER_IP_PER_HOUR=20

# From address used for outgoing mail.
# Required: no
# Default: no-reply@example.com
MAILER_FROM=no-reply@example.com

# SMTP host.
# Required: yes
SMTP_HOST=

# SMTP port.
# Required: yes
SMTP_PORT=

# SMTP authentication username.
# Required: yes
SMTP_USER=

# SMTP authentication password.
# Required: yes
SMTP_PASSWORD=

# SMS provider. "log" prints to stdout. "smso" uses SMSO.ro.
# Required: no
# Default: log
SMS_PROVIDER=log

# SMSO.ro API key. Required when SMS_PROVIDER=smso.
# Required: no
SMSO_API_KEY=

# SMSO.ro sender ID. Required when SMS_PROVIDER=smso.
# Required: no
SMSO_SENDER=

# Relaxed per-endpoint request ceiling per direct IP per minute.
# Required: no
# Default: 1000
THROTTLE_GLOBAL_PER_IP_PER_MIN=1000

# Max OTP request/resend calls per direct IP per minute.
# Required: no
# Default: 10
THROTTLE_OTP_REQUESTS_PER_IP_PER_MIN=10

# Max login attempts per IP per minute.
# Required: no
# Default: 10
THROTTLE_LOGIN_PER_IP_PER_MIN=10

# Run daily 03:00 cleanup of expired refresh tokens and stale OTP rows.
# Required: no
# Default: true
AUTH_CLEANUP_ENABLED=true
