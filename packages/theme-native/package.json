{
  "name": "@repo/theme-native",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./configure": {
      "types": "./src/configure.ts",
      "default": "./src/configure.ts"
    },
    "./styles": {
      "types": "./src/styles.ts",
      "default": "./src/styles.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/theme": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.76",
    "react-native-unistyles": ">=3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
