{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./Badge": {
      "types": "./src/Badge.tsx",
      "default": "./src/Badge.tsx"
    },
    "./BottomSheet": {
      "types": "./src/BottomSheet.tsx",
      "default": "./src/BottomSheet.tsx"
    },
    "./Button": {
      "types": "./src/Button.tsx",
      "default": "./src/Button.tsx"
    },
    "./Card": {
      "types": "./src/Card.tsx",
      "default": "./src/Card.tsx"
    },
    "./Divider": {
      "types": "./src/Divider.tsx",
      "default": "./src/Divider.tsx"
    },
    "./Input": {
      "types": "./src/Input.tsx",
      "default": "./src/Input.tsx"
    },
    "./Select": {
      "types": "./src/Select.tsx",
      "default": "./src/Select.tsx"
    },
    "./Snackbar": {
      "types": "./src/Snackbar.tsx",
      "default": "./src/Snackbar.tsx"
    },
    "./Text": {
      "types": "./src/Text.tsx",
      "default": "./src/Text.tsx"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "shadcn:add": "shadcn add",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@repo/theme": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.2",
    "vite": "^7.0.0"
  }
}
