{
  "name": "@repo/i18n",
  "version": "0.0.0",
  "private": true,
  "description": "Shared locale contract, message catalogs, and dependency-free formatting helpers for API, web, and mobile apps.",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./messages": {
      "types": "./src/messages.ts",
      "default": "./dist/messages.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  }
}
