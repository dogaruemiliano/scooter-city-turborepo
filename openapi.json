              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnabledAuthMethods_Output"
                }
              }
            }
          }
        },
        "summary": "Which auth methods this API has enabled. Drives conditional UI on the web/mobile clients.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "operationId": "CoreAuthController_refresh_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          }
        },
        "summary": "Rotate the refresh token (cookie or body)",
        "tags": ["auth"]
      }
    },
    "/v1/auth/logout": {
      "post": {
        "operationId": "CoreAuthController_logout_v1",
        "parameters": [],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Revoke the current session",
        "tags": ["auth"]
      }
    },
    "/v1/auth/logout-all": {
      "post": {
        "operationId": "CoreAuthController_logoutAll_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutAllResult_Output"
                }
              }
            }
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Revoke every session of the current user (including this one)",
        "tags": ["auth"]
      }
    },
    "/v1/auth/sessions": {
      "get": {
        "operationId": "CoreAuthController_listSessions_v1",
        "parameters": [],
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionSummary_Output"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "List active sessions ('devices')",
        "tags": ["auth"]
      }
    },
    "/v1/auth/sessions/{id}": {
      "delete": {
        "operationId": "CoreAuthController_revokeSpecificSession_v1",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Revoke one specific session",
        "tags": ["auth"]
      }
    },
    "/v1/auth/me": {
      "get": {
        "operationId": "CoreAuthController_me_v1",
        "parameters": [],
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionUser_Output"
                }
              }
            }
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Current user profile",
        "tags": ["auth"]
      },
      "patch": {
        "operationId": "CoreAuthController_updateProfile_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileInput"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionUser_Output"
                }
              }
            }
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Update the current user's editable profile fields",
        "tags": ["auth"]
      },
      "delete": {
        "operationId": "CoreAuthController_deleteMe_v1",
        "parameters": [],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Hard-delete the current user. Cascades sessions, refresh tokens, OTPs, and OAuth links. Audit events survive.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/accounts/{provider}": {
      "delete": {
        "operationId": "CoreAuthController_unlinkOAuthAccount_v1",
        "parameters": [
          {
            "name": "provider",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Unlink an OAuth identity. Refuses if doing so would leave the user with no remaining auth method.",
        "tags": ["auth"]
      }
    },
    "/.well-known/jwks.json": {
      "get": {
        "description": "Includes the current signing key and (during a rotation window) the previous one. Consumers should respect Cache-Control and refresh on `kid` cache miss.",
        "operationId": "JwksController_getJwks",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Public JWK set for RS256 access-token verification",
        "tags": ["auth"]
      }
    },
    "/v1/auth/email-otp/request": {
      "post": {
        "operationId": "EmailOtpController_request_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestEmailOtpInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpChallengeMetadata_Output"
                }
              }
            }
          }
        },
        "summary": "Start or resume passwordless email sign-up/sign-in and return an opaque challenge ID.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/email-otp/verify": {
      "post": {
        "operationId": "EmailOtpController_verify_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailOtpInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "Invalid, expired, used, cross-purpose, or attempt-locked challenge."
          }
        },
        "summary": "Email-OTP verify: exchange a valid code for a fresh session (cookies set + TokenPair returned).",
        "tags": ["auth"]
      }
    },
    "/v1/auth/google": {
      "post": {
        "description": "Exchanges a Google ID token (from Google Identity Services on web, or the native Google Sign-In SDK on mobile) for a first-party session. Verification is local: we check the JWT signature, expiry, and audience against the configured `GOOGLE_CLIENT_ID_*` client IDs. Google's token is discarded after verification — subsequent requests authenticate with the access/refresh tokens this endpoint returns.",
        "operationId": "GoogleAuthController_signin_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInWithGoogleInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Provider identity resolved; first-party session issued.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "202": {
            "description": "The provider did not verify the email. A one-time code was sent and must be submitted to /v1/auth/oauth-email/verify.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpChallengeMetadata_Output"
                }
              }
            }
          },
          "401": {
            "description": "The Google identity token failed verification."
          }
        },
        "summary": "Sign in with a Google-issued ID token",
        "tags": ["auth"]
      }
    },
    "/v1/auth/apple": {
      "post": {
        "description": "Verifies the JWT against Apple's JWKS. On success, resolves or creates the user, issues a session, sets HttpOnly cookies, and returns a TokenPair. See docs/auth/apple-signin.md for the auto-link decision matrix.",
        "operationId": "AppleAuthController_signin_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInWithAppleInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Provider identity resolved; first-party session issued.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "202": {
            "description": "Apple did not verify the email. A one-time code was sent and must be submitted to /v1/auth/oauth-email/verify.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpChallengeMetadata_Output"
                }
              }
            }
          },
          "401": {
            "description": "The token failed verification, or an unlinked Apple identity omitted email entirely."
          }
        },
        "summary": "Exchange an Apple identity token for an API session.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/otp/resend": {
      "post": {
        "operationId": "OtpChallengeController_resend_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResendOtpChallengeInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpChallengeMetadata_Output"
                }
              }
            }
          },
          "401": {
            "description": "The challenge is missing, used, expired, or locked."
          }
        },
        "summary": "Resend an OTP challenge when its server-controlled cooldown has elapsed.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/oauth-email/verify": {
      "post": {
        "operationId": "OAuthEmailVerificationController_verify_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyOAuthEmailInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired code. Missing, used, expired, locked, and wrong-code challenges return the same response."
          }
        },
        "summary": "Complete an OAuth sign-in by proving ownership of an email the provider did not mark as verified.",
        "tags": ["auth"]
      }
    }
  },
  "info": {
    "title": "Turborepo Full Template API",
    "description": "REST API surface. All operations live under /v1.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "HTTP-only access-token cookie."
      },
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "EnabledAuthMethods_Output": {
        "type": "object",
        "properties": {
          "methods": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["emailOtp", "google", "apple"]
            }
          }
        },
        "required": ["methods"],
        "additionalProperties": false
      },
      "RefreshTokenInput": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "description": "Refresh token (mobile clients without a cookie jar pass it in the body). Ignored when an `access_token` cookie is present and valid.",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TokenPair_Output": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Signed access JWT. Also set as the `access_token` HttpOnly cookie; mobile clients consume the body field."
          },
          "refreshToken": {
            "type": "string",
            "description": "Signed refresh JWT. Also set as the `refresh_token` HttpOnly cookie."
          }
        },
        "required": ["accessToken", "refreshToken"],
        "additionalProperties": false
      },
      "LogoutAllResult_Output": {
        "type": "object",
        "properties": {
          "sessionsRevoked": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991,
            "description": "Number of sessions revoked, including the caller's current session."
          }
        },
        "required": ["sessionsRevoked"],
        "additionalProperties": false
      },
      "SessionSummary_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userAgent": {
            "type": "string",
            "nullable": true
          },
          "ip": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "lastUsedAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "current": {
            "type": "boolean",
            "description": "True for the session whose refresh token issued the current request."
          }
        },
        "required": [
          "id",
          "userAgent",
          "ip",
          "createdAt",
          "lastUsedAt",
          "current"
        ],
        "additionalProperties": false
      },
      "SessionUser_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "emailVerified": {
            "type": "string",
            "description": "ISO timestamp of email verification, or `null` if unverified.",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "phoneVerified": {
            "type": "string",
            "description": "ISO timestamp of phone verification, or `null` if unverified.",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Authorization roles. Snapshot also lives in the access-JWT claims; reflects this user's current grants."
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp of account creation."
          },
          "linkedProviders": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["google", "apple"]
            }
          }
        },
        "required": [
          "id",
          "email",
          "emailVerified",
          "phone",
          "phoneVerified",
          "firstName",
          "lastName",
          "roles",
          "createdAt",
          "linkedProviders"
        ],
        "additionalProperties": false
      },
      "UpdateProfileInput": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RequestEmailOtpInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
            "description": "Email address to send the one-time code to. Treated case-insensitively."
          }
        },
        "required": ["email"],
        "additionalProperties": false
      },
      "OtpChallengeMetadata_Output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["verification_required"]
          },
          "challengeId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "description": "Opaque UUID identifying one OTP challenge."
          },
          "expiresInSec": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "description": "Seconds until the challenge expires."
          },
          "resendAfterSec": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Seconds until another delivery may be requested."
          }
        },
        "required": ["status", "challengeId", "expiresInSec", "resendAfterSec"],
        "additionalProperties": false
      },
      "VerifyEmailOtpInput": {
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "description": "Opaque UUID identifying one OTP challenge."
          },
          "code": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "description": "The 6-digit one-time code. In non-production `NODE_ENV`, the API accepts the literal `\"000000\"`."
          }
        },
        "required": ["challengeId", "code"],
        "additionalProperties": false
      },
      "SignInWithGoogleInput": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 20,
            "description": "Google-issued ID token (JWT) from Google Identity Services or the native SDK."
          }
        },
        "required": ["idToken"],
        "additionalProperties": false
      },
      "SignInWithAppleInputAppleFullName": {
        "type": "object",
        "properties": {
          "givenName": {
            "type": "string",
            "maxLength": 80,
            "nullable": true
          },
          "familyName": {
            "type": "string",
            "maxLength": 80,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SignInWithAppleInput": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 20,
            "description": "Apple-issued identity token (JWT) from Sign in with Apple JS or the native SDK."
          },
          "fullName": {
            "description": "Optional name payload Apple sends only on the very first sign-in. Used as a hint when creating a new User.",
            "$ref": "#/components/schemas/SignInWithAppleInputAppleFullName"
          }
        },
        "required": ["idToken"],
        "additionalProperties": false
      },
      "ResendOtpChallengeInput": {
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string",
            "format": "uuid",
