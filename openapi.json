            }
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Which auth methods this API has enabled. Drives conditional UI on the web/mobile clients.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/email-otp/request": {
      "post": {
        "operationId": "EmailOtpController_request_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestEmailOtpInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpRequestResponse_Output"
                }
              }
            }
          }
        },
        "summary": "Email-OTP request: mail a single-use 6-digit code if the email matches a real user. Always returns 202; the response does not disclose whether the address is known.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/email-otp/verify": {
      "post": {
        "operationId": "EmailOtpController_verify_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailOtpInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired code. The response is intentionally identical whether the email is unknown, the row is expired, the code is wrong, or the row has hit OTP_MAX_ATTEMPTS."
          }
        },
        "summary": "Email-OTP verify: exchange a valid code for a fresh session (cookies set + TokenPair returned).",
        "tags": ["auth"]
      }
    },
    "/v1/auth/google": {
      "post": {
        "description": "Exchanges a Google ID token (from Google Identity Services on web, or the native Google Sign-In SDK on mobile) for a first-party session. Verification is local: we check the JWT signature, expiry, and audience against the configured `GOOGLE_CLIENT_ID_*` client IDs. Google's token is discarded after verification — subsequent requests authenticate with the access/refresh tokens this endpoint returns.",
        "operationId": "GoogleAuthController_signin_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInWithGoogleInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "The provided ID token failed signature, audience, or expiry verification."
          },
          "409": {
            "description": "An account with the same email exists locally, but Google has not verified that email. Sign in via another method and link Google from settings."
          }
        },
        "summary": "Sign in with a Google-issued ID token",
        "tags": ["auth"]
      }
    },
    "/v1/auth/apple": {
      "post": {
        "description": "Verifies the JWT against Apple's JWKS. On success, resolves or creates the user, issues a session, sets HttpOnly cookies, and returns a TokenPair. See docs/auth/apple-signin.md for the auto-link decision matrix.",
        "operationId": "AppleAuthController_signin_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInWithAppleInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "Apple identity token failed verification (signature, audience, issuer, expiry), or a subsequent sign-in arrived without a known AuthAccount row."
          },
          "409": {
            "description": "A user with this email exists but the email is not verified on our side. Sign in via another method first, then link Apple from settings."
          }
        },
        "summary": "Exchange an Apple identity token for an API session.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/sms-otp/request": {
      "post": {
        "operationId": "SmsOtpController_request_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestSmsOtpInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsOtpRequestResponse_Output"
                }
              }
            }
          }
        },
        "summary": "SMS-OTP request: send a single-use 6-digit code if the phone matches a real user. Always returns 202; the response does not disclose whether the number is known.",
        "tags": ["auth"]
      }
    },
    "/v1/auth/sms-otp/verify": {
      "post": {
        "operationId": "SmsOtpController_verify_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifySmsOtpInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPair_Output"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired code. The response is intentionally identical whether the phone is unknown, the row is expired, the code is wrong, or the row has hit OTP_MAX_ATTEMPTS."
          }
        },
        "summary": "SMS-OTP verify: exchange a valid code for a fresh session (cookies set + TokenPair returned).",
        "tags": ["auth"]
      }
    }
  },
  "info": {
    "title": "Turborepo Full Template API",
    "description": "REST API surface. All operations live under /v1.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "HTTP-only access-token cookie."
      },
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RefreshTokenInput": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "description": "Refresh token (mobile clients without a cookie jar pass it in the body). Ignored when an `access_token` cookie is present and valid.",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TokenPair_Output": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Signed access JWT. Also set as the `access_token` HttpOnly cookie; mobile clients consume the body field."
          },
          "refreshToken": {
            "type": "string",
            "description": "Signed refresh JWT. Also set as the `refresh_token` HttpOnly cookie."
          }
        },
        "required": ["accessToken", "refreshToken"],
        "additionalProperties": false
      },
      "LogoutAllResult_Output": {
        "type": "object",
        "properties": {
          "sessionsRevoked": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991,
            "description": "Number of sessions revoked, excluding the caller's current session."
          }
        },
        "required": ["sessionsRevoked"],
        "additionalProperties": false
      },
      "SessionUser_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "emailVerified": {
            "type": "string",
            "description": "ISO timestamp of email verification, or `null` if unverified.",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "phoneVerified": {
            "type": "string",
            "description": "ISO timestamp of phone verification, or `null` if unverified.",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp of account creation."
          }
        },
        "required": [
          "id",
          "email",
          "emailVerified",
          "phone",
          "phoneVerified",
          "firstName",
          "lastName",
          "createdAt"
        ],
        "additionalProperties": false
      },
      "SessionSummary_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userAgent": {
            "type": "string",
            "nullable": true
          },
          "ip": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "lastUsedAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "current": {
            "type": "boolean",
            "description": "True for the session whose refresh token issued the current request."
          }
        },
        "required": [
          "id",
          "userAgent",
          "ip",
          "createdAt",
          "lastUsedAt",
          "current"
        ],
        "additionalProperties": false
      },
      "EnabledAuthMethods_Output": {
        "type": "object",
        "properties": {
          "emailOtp": {
            "type": "boolean"
          },
          "smsOtp": {
            "type": "boolean"
          },
          "google": {
            "type": "boolean"
          },
          "apple": {
            "type": "boolean"
          }
        },
        "required": ["emailOtp", "smsOtp", "google", "apple"],
        "additionalProperties": false
      },
      "RequestEmailOtpInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
            "description": "Email address to send the one-time code to. Treated case-insensitively (normalized to lowercase before lookup)."
          }
        },
        "required": ["email"],
        "additionalProperties": false
      },
      "OtpRequestResponse_Output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Constant acknowledgement of the request. Returned unconditionally — whether the email matched a real user is intentionally not disclosed (anti-enumeration).",
            "enum": ["sent"]
          }
        },
        "required": ["status"],
        "additionalProperties": false
      },
      "VerifyEmailOtpInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
            "description": "Email address that received the code. Must match the address used in the preceding /request call."
          },
          "code": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "description": "The 6-digit one-time code. In non-production `NODE_ENV`, the API accepts the literal `\"000000\"`."
          }
        },
        "required": ["email", "code"],
        "additionalProperties": false
      },
      "SignInWithGoogleInput": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 20,
            "description": "Google-issued ID token (JWT) from Google Identity Services or the native SDK."
          }
        },
        "required": ["idToken"],
        "additionalProperties": false
      },
      "SignInWithAppleInputAppleFullName": {
        "type": "object",
        "properties": {
          "givenName": {
            "type": "string",
            "maxLength": 80,
            "nullable": true
          },
          "familyName": {
            "type": "string",
            "maxLength": 80,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SignInWithAppleInput": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 20,
            "description": "Apple-issued identity token (JWT) from Sign in with Apple JS or the native SDK."
          },
          "fullName": {
            "description": "Optional name payload Apple sends only on the very first sign-in. Used as a hint when creating a new User.",
            "$ref": "#/components/schemas/SignInWithAppleInputAppleFullName"
          }
        },
        "required": ["idToken"],
        "additionalProperties": false
      },
      "RequestSmsOtpInput": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{6,14}$",
            "description": "Phone number to send the one-time code to, in E.164 format (e.g. +40712345678)."
          }
        },
        "required": ["phone"],
        "additionalProperties": false
      },
      "SmsOtpRequestResponse_Output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Constant acknowledgement of the request. Returned unconditionally — whether the phone matched a real user is intentionally not disclosed (anti-enumeration).",
            "enum": ["sent"]
          }
        },
        "required": ["status"],
        "additionalProperties": false
      },
      "VerifySmsOtpInput": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{6,14}$",
            "description": "Phone number that received the code. Must match the number used in the preceding /request call."
          },
          "code": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "description": "The 6-digit one-time code. In non-production `NODE_ENV`, the API accepts the literal `\"000000\"`."
          }
        },
        "required": ["phone", "code"],
        "additionalProperties": false
      }
    }
  }
}
