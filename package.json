{
  "name": "turborepo-full-template-v2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "init:local": "tsx scripts/init-local.ts",
    "gen": "pnpm gen:env && pnpm --filter @repo/api-shared build && pnpm --filter api build && pnpm gen:openapi",
    "gen:env": "tsx scripts/generate-env-example.ts",
    "gen:openapi": "node apps/api/dist/src/main --spec-only > openapi.json",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^1.8.4",
    "lint-staged": "^15.2.10",
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "turbo": "^2.9.12",
    "typescript": "5.9.2",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.7",
      "jest-mock": "^30.0.0",
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  }
}
